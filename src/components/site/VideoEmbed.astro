---
interface Props {
  title?: string;
  src?: string;
}

const {
  title = 'Introducing Promptless 1.0',
  src = 'https://www.tella.tv/video/vid_cmkc3e0h900h804ii26qp01mo/embed?feature=oembed',
} = Astro.props;
---

<section id="overview">
  <div class="pl-site-video-embed">
    <iframe
      id="demo-video"
      src={src}
      title={title}
      allowfullscreen
      allow="accelerometer *; encrypted-media *; gyroscope *; picture-in-picture *; fullscreen *"
    />
  </div>
</section>

<script is:inline>
(() => {
  const iframe = document.getElementById('demo-video');
  if (!iframe) return;
  const ph = () => window.posthog;

  // Track clicks into the iframe (proxy for "started watching")
  // When a user clicks an iframe, the main window loses focus.
  let clicked = false;
  window.addEventListener('blur', () => {
    if (clicked) return;
    // Check after a tick so activeElement updates
    setTimeout(() => {
      if (document.activeElement === iframe) {
        clicked = true;
        ph()?.capture('demo:video_clicked');
      }
    }, 0);
  });

  // Track cumulative time the video was visible on page leave
  let visibleSeconds = 0;
  let lastTick = null;

  const tickObs = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      lastTick = Date.now();
    } else if (lastTick) {
      visibleSeconds += (Date.now() - lastTick) / 1000;
      lastTick = null;
    }
  }, { threshold: 0.5 });
  tickObs.observe(iframe);

  const sendEngagement = () => {
    if (lastTick) {
      visibleSeconds += (Date.now() - lastTick) / 1000;
      lastTick = null;
    }
    if (visibleSeconds > 1) {
      ph()?.capture('demo:video_watched', {
        watch_time_seconds: Math.round(visibleSeconds),
        clicked_video: clicked,
      }, { transport: 'sendBeacon' });
    }
  };

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') sendEngagement();
  });
})();
</script>
