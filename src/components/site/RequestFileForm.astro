---
---

<div class="rff-wrapper" id="request-file-form-wrapper">
  <form
    class="rff-form"
    id="request-file-form"
    action="https://submit-form.com/zmlFaDayx"
    novalidate
  >
    <div class="rff-row">
      <input
        id="rff-email"
        name="email"
        type="email"
        inputmode="email"
        placeholder="you@company.com"
        autocomplete="email"
        required
      />
      <button type="submit">Request file</button>
    </div>
    <p id="rff-status" class="rff-status" aria-live="polite"></p>
  </form>

  <div class="rff-success" id="rff-success" hidden>
    <span class="rff-check" aria-hidden="true">✓</span>
    <span>We'll send it over shortly!</span>
  </div>
</div>

<script is:inline>
  (() => {
    const form = document.getElementById('request-file-form');
    if (!(form instanceof HTMLFormElement)) return;

    const status = document.getElementById('rff-status');
    const successEl = document.getElementById('rff-success');
    const submitBtn = form.querySelector('button[type="submit"]');
    if (!(submitBtn instanceof HTMLButtonElement)) return;

    const isValidEmail = (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());

    const setStatus = (msg, tone) => {
      if (!status) return;
      status.textContent = msg;
      status.dataset.tone = tone || 'neutral';
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      setStatus('');

      const email = String(new FormData(form).get('email') || '').trim();
      if (!isValidEmail(email)) {
        setStatus('Please enter a valid work email.', 'error');
        return;
      }

      submitBtn.disabled = true;
      setStatus('Sending…', 'neutral');

      try {
        const res = await fetch('https://submit-form.com/zmlFaDayx', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (!res.ok) throw new Error('Submission failed');

        form.hidden = true;
        if (successEl) successEl.hidden = false;
      } catch {
        setStatus('Something went wrong. Please try again.', 'error');
        submitBtn.disabled = false;
      }
    });
  })();
</script>

<style>
  .rff-wrapper {
    margin-top: 1.25rem;
  }

  .rff-form {
    display: grid;
    gap: 0.5rem;
    max-width: 28rem;
  }

  .rff-row {
    display: flex;
    gap: 0.5rem;
  }

  .rff-row input {
    flex: 1;
    min-width: 0;
    min-height: 2.6rem;
    border: 1px solid #d2d9e7;
    border-radius: 0.55rem;
    background: #fff;
    color: #111827;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.55rem 0.75rem;
  }

  .rff-row input:focus {
    outline: 2px solid color-mix(in srgb, #4f6fee 34%, transparent);
    outline-offset: 0;
    border-color: #4f6fee;
  }

  .rff-row button {
    white-space: nowrap;
    flex-shrink: 0;
    border: 1px solid #0f172a;
    border-radius: 0.55rem;
    background: #0f172a;
    color: #fff;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.66rem 1rem;
    cursor: pointer;
    transition: background 120ms ease, border-color 120ms ease;
  }

  .rff-row button:hover {
    background: #1e293b;
    border-color: #1e293b;
  }

  .rff-row button:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .rff-status {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.4;
    color: #475569;
    min-height: 1.2em;
  }

  .rff-status[data-tone='error'] {
    color: #b42318;
  }

  .rff-success {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: #0f766e;
  }

  .rff-success[hidden] {
    display: none;
  }

  .rff-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: #0f766e;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }
</style>
